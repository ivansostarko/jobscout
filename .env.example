# ==== JobScout secrets — copy to .env and fill in ====

# Telegram (create a bot with @BotFather, get your chat id with @userinfobot)
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# Email / SMTP (for Gmail use an App Password, port 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Optional: Facebook session cookie (see docs/SOURCES.md — disabled by default,
# using it may violate Facebook ToS)
#FB_COOKIE=

# Optional overrides
#JOBSCOUT_CONFIG=/absolute/path/to/jobscout.yaml
#OLLAMA_HOST=http://localhost:11434
